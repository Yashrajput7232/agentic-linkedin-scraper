# ─────────────────────────────────────────────
# MongoDB Atlas
# ─────────────────────────────────────────────
# Paste your full Atlas connection string here.
# Example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/

# Name of the database to use (will be created automatically)
MONGODB_DB_NAME=linkedin_jobs

# ─────────────────────────────────────────────
# LinkedIn Credentials (for scraping)
# ─────────────────────────────────────────────
# Account used for job *search* requests
LINKEDIN_SEARCH_EMAIL=your_email@example.com
LINKEDIN_SEARCH_PASSWORD=your_password

# Account(s) used for job *detail* requests
# Comma-separated if you want multiple accounts for rotation
LINKEDIN_DETAILS_EMAILS=your_email@example.com
LINKEDIN_DETAILS_PASSWORDS=your_password
